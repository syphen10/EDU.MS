<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_better_report_form" model="ir.ui.view">
        <field name="name">better.report.form</field>
        <field name="model">better.report</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_run_report" string="▶ Compile Report" type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" placeholder="Report Name"/></h1></div>
                    <group>
                        <field name="model_id"/>
                        <field name="record_limit"/>
                    </group>
                    <notebook>
                        <page string="Columns">
                            <field name="field_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_better_report" model="ir.actions.act_window">
        <field name="name">Better Reports</field>
        <field name="res_model">better.report</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_better_report_root" name="Better Reports" sequence="99"/>
    <menuitem id="menu_better_report_list" name="My Reports" parent="menu_better_report_root" action="action_better_report"/>
</odoo>
