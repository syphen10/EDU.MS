<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_better_report_tree" model="ir.ui.view">
        <field name="name">better.report.tree</field>
        <field name="model">better.report</field>
        <field name="arch" type="xml">
            <tree string="Better Reports">
                <field name="name"/>
                <field name="report_type"/>
                <field name="date_from"/>
                <field name="date_to"/>
            </tree>
        </field>
    </record>

    <record id="view_better_report_form" model="ir.ui.view">
        <field name="name">better.report.form</field>
        <field name="model">better.report</field>
        <field name="arch" type="xml">
            <form string="Better Report">
                <header>
                    <button name="action_run_report" string="▶ Compile Report" type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="E.g., Q3 Trial Balance"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="report_type"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                        <group>
                            <field name="allowed_group_ids" widget="many2many_tags" placeholder="Restrict to specific groups..."/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_better_report" model="ir.actions.act_window">
        <field name="name">Better Reports</field>
        <field name="res_model">better.report</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_better_report_root" name="Better Reports" sequence="10"/>
    <menuitem id="menu_better_report_main" name="Reports" parent="menu_better_report_root" action="action_better_report"/>
</odoo>
